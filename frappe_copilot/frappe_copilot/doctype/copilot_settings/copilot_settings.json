{
  "name": "Copilot Settings",
  "module": "Frappe Copilot",
  "doctype": "DocType",
  "issingle": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "0",
      "description": "Enable the Copilot sidebar"
    },
    {
      "fieldname": "agent_url",
      "fieldtype": "Data",
      "label": "Agent URL",
      "default": "ws://localhost:8484",
      "reqd": 1,
      "description": "WebSocket URL of the Copilot Agent service"
    },
    {
      "fieldname": "sidebar_width",
      "fieldtype": "Int",
      "label": "Sidebar Width",
      "default": "380",
      "description": "Width of the sidebar in pixels (300-600)"
    },
    {
      "fieldname": "keyboard_shortcut",
      "fieldtype": "Data",
      "label": "Keyboard Shortcut",
      "default": "Ctrl+/",
      "description": "Toggle shortcut for the sidebar"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
